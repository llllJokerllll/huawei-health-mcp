# Huawei Health MCP Backend API Configuration

# App Settings
APP_NAME=Huawei Health MCP API
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# Huawei OAuth Credentials (get from Huawei Developer Portal)
HUAWEI_CLIENT_ID=your_client_id_here
HUAWEI_CLIENT_SECRET=your_client_secret_here
HUAWEI_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Huawei API Base URL
HUAWEI_API_BASE_URL=https://health-api.cloud.huawei.com/healthkit/v1/

# OAuth Endpoints
HUAWEI_AUTH_URI=https://oauth-login.cloud.huawei.com/oauth2/v3/authorize
HUAWEI_TOKEN_URI=https://oauth-login.cloud.huawei.com/oauth2/v3/token

# OAuth Scopes
HUAWEI_SCOPES=https://www.huawei.com/healthkit

# Database (SQLite)
DATABASE_PATH=./data/health_data.db

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here
